<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.kampala.Controllers.AdminController">
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15;" spacing="10">
            <Label text="Administrators" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="+ Add Admin" onAction="#goToAddAdmin"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
            <Button text="← Dashboard" onAction="#goToDashboard"
                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox spacing="5" style="-fx-background-color: #34495e; -fx-padding: 10;" prefWidth="180">
            <Button text="🏠  Dashboard" onAction="#showDashboard" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button text="👤  Vendors" onAction="#showVendors" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button text="🏪  Markets" onAction="#showMarkets" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button text="👮  Administrators" onAction="#showAdmins" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button text="📋  Unassigned Vendors" onAction="#showUnassigned" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
        </VBox>
    </left>
    
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <TableView fx:id="adminsTable" VBox.vgrow="ALWAYS" onMouseClicked="#handleAdminClick">
                <columns>
                    <TableColumn fx:id="colId"       text="ID"       prefWidth="50"/>
                    <TableColumn fx:id="colName"     text="Name"     prefWidth="160"/>
                    <TableColumn fx:id="colUsername"  text="Username" prefWidth="120"/>
                    <TableColumn fx:id="colEmail"    text="Email"    prefWidth="180"/>
                    <TableColumn fx:id="colRole"     text="Role"     prefWidth="120"/>
                    <TableColumn fx:id="colZone"     text="Zone"     prefWidth="120"/>
                    <TableColumn fx:id="colStatus"   text="Status"   prefWidth="90"/>
                </columns>
            </TableView>
            <Label fx:id="statusLabel" style="-fx-text-fill: #7f8c8d;"/>
        </VBox>
    </center>
</BorderPane>