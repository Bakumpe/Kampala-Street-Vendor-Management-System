<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.kampala.Controllers.LoginController">

    <Label text="Kampala Street Vendor MS" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TextField fx:id="usernameField" promptText="Username" maxWidth="250"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="250"/>
    <Button text="Login" onAction="#handleLogin" maxWidth="250"/>
    <Label fx:id="messageLabel" style="-fx-text-fill: red;"/>

</VBox>