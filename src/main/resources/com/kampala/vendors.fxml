<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.kampala.Controllers.VendorController">

    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15;" spacing="10">
            <Label text="Vendors" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="+ Add Vendor" onAction="#goToAddVendor"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
            <Button text="← Back" onAction="#goToDashboard"
                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Search vendors..." prefWidth="300"
                           onKeyReleased="#handleSearch"/>
                <ComboBox fx:id="statusFilter" promptText="Filter by status" onAction="#handleSearch"/>
            </HBox>

            <TableView fx:id="vendorsTable" VBox.vgrow="ALWAYS" onMouseClicked="#handleVendorClick">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colName" text="Full Name" prefWidth="160"/>
                    <TableColumn fx:id="colType" text="Vendor Type" prefWidth="130"/>
                    <TableColumn fx:id="colMarket" text="Assigned Market" prefWidth="150"/>
                    <TableColumn fx:id="colLicence" text="Licence No." prefWidth="140"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                </columns>
            </TableView>

            <Label fx:id="statusLabel" style="-fx-text-fill: #7f8c8d;"/>
        </VBox>
    </center>

</BorderPane>