<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.kampala.Controllers.AdminProfileController">
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="Admin Profile" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="← Back" onAction="#goToAdmins"
                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="20" style="-fx-padding: 30;" maxWidth="600">

            <VBox style="-fx-background-color: #2c3e50; -fx-padding: 25; -fx-background-radius: 10;">
                <Label fx:id="fullNameLabel" text="Admin Name"
                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label fx:id="usernameLabel" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;"/>
                <Label fx:id="statusBadge" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            </VBox>

            <Label text="Details" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
            <GridPane hgap="15" vgap="10">
                <Label text="Email:"  GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
                <Label fx:id="emailLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label text="Role:"   GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                <Label fx:id="roleLabel"  GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="Zone:"   GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
                <Label fx:id="zoneLabel"  GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            </GridPane>

            <Label text="Update Role &amp; Zone" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
            <HBox spacing="10">
                <ComboBox fx:id="roleComboBox" prefWidth="180"/>
                <TextField fx:id="zoneField" promptText="Zone (optional)" HBox.hgrow="ALWAYS"/>
                <Button text="Update" onAction="#handleUpdateRole"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
            </HBox>

            <HBox spacing="10">
                <Button text="Deactivate" onAction="#handleDeactivate"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                <Button text="Activate" onAction="#handleActivate"
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
            </HBox>

            <Label fx:id="messageLabel" style="-fx-font-size: 13px;"/>
        </VBox>
    </center>
</BorderPane>