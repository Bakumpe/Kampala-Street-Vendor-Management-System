<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.kampala.Controllers.DashboardController">

    <!-- TOP NAV BAR -->
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="Kampala Street Vendor Management System"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox spacing="5" style="-fx-background-color: #34495e; -fx-padding: 10;" prefWidth="180">
            <Button text="🏠  Dashboard" onAction="#showDashboard" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button text="👤  Vendors" onAction="#showVendors" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button text="🏪  Markets" onAction="#showMarkets" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button text="👮  Administrators" onAction="#showAdmins" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button text="📋  Unassigned Vendors" onAction="#showUnassigned" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT AREA -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20;">

            <!-- STATS CARDS -->
            <HBox spacing="15">
                <VBox style="-fx-background-color: #3498db; -fx-padding: 20; -fx-pref-width: 160; -fx-background-radius: 8;">
                    <Label text="Total Vendors" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                    <Label fx:id="totalVendorsLabel" text="0"
                           style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                </VBox>
                <VBox style="-fx-background-color: #2ecc71; -fx-padding: 20; -fx-pref-width: 160; -fx-background-radius: 8;">
                    <Label text="Active Vendors" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                    <Label fx:id="activeVendorsLabel" text="0"
                           style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                </VBox>
                <VBox style="-fx-background-color: #e67e22; -fx-padding: 20; -fx-pref-width: 160; -fx-background-radius: 8;">
                    <Label text="Markets" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                    <Label fx:id="totalMarketsLabel" text="0"
                           style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                </VBox>
                <VBox style="-fx-background-color: #e74c3c; -fx-padding: 20; -fx-pref-width: 160; -fx-background-radius: 8;">
                    <Label text="Unassigned Vendors" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                    <Label fx:id="unassignedLabel" text="0"
                           style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- RECENT VENDORS TABLE -->
            <Label text="Recent Vendors" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <TableView fx:id="vendorsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colName" text="Name" prefWidth="150"/>
                    <TableColumn fx:id="colVendorType" text="Vendor Type" prefWidth="130"/>
                    <TableColumn fx:id="colMarket" text="Assigned Market" prefWidth="150"/>
                    <TableColumn fx:id="colLicence" text="Licence No." prefWidth="150"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                </columns>
            </TableView>

        </VBox>
    </center>

    <!-- STATUS BAR -->
    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 8;">
            <Label fx:id="statusLabel" text="Welcome to Kampala Street Vendor MS"
                   style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
        </HBox>
    </bottom>

</BorderPane>